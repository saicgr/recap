# Copy to .env for local dev (never commit .env). On Render, set these in the
# dashboard (render.yaml marks the secrets sync:false).

# Google Gemini API key — the whole reason this proxy exists (app holds no keys).
GEMINI_API_KEY=

# Server-only secret used to HMAC install tokens. Generate a long random value:
#   openssl rand -hex 32
INSTALL_TOKEN_PEPPER=

# Optional overrides (defaults shown).
PORT=10000
RATE_LIMIT_AUTH_PER_HOUR=600
RATE_LIMIT_UNAUTH_PER_HOUR=60
DAILY_BUDGET_USD=10
EST_COST_PER_SUMMARY_USD=0.005
